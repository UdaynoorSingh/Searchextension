{
    "manifest_version": 3,
    "name": "Smart Search",
    "version": "1.0.0",
    "description": "A brief, plain text summary of the extension's purpose.",
    "action": {
        "default_title": "Click Me!"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "./content-scripts/core/initializer.js",
                "./content-scripts/core/constants.js",
                "./content-scripts/core/normalizer.js",
                "./content-scripts/core/parser.js",
                "./content-scripts/core/highlighter.js",
                "./content-scripts/content.js"
            ],
            "css": [
                "./content-scripts/css/content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "commands": {
        "search-current-page": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Search in current page"
        }
    },
    "short_name": "AwesomeExt",
    "version_name": "1.0 Beta",
    "minimum_chrome_version": "102"
}