{
    "manifest_version": 3,
    "name": "Majo - Smartest Ctrl+F, Find-in-page Search",
    "short_name": "Majo Search",
    "version": "1.0.0",
    "version_name": "Magic 0",
    "description": "Replace Ctrl+F with advanced find-in-page features like regex, typo-tolerance, and sounds-alike matching.",
    "icons": {
        "16": "assets/16.png",
        "32": "assets/32.png",
        "48": "assets/48.png",
        "128": "assets/128.png"
    },
    "action": {
        "default_title": "Search in current page",
        "default_icon": {
            "16": "assets/16.png",
            "24": "assets/24.png",
            "32": "assets/32.png"
        }
    },
    "background": {
        "service_worker": "./background/dist/background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "notifications",
        "alarms",
        "contextMenus",
        "tabs"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/loading-circle.gif"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "./content/dist/content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "commands": {
        "search-current-page": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Search in current page"
        }
    },
    "options_ui": {
        "page": "page-options/dist/index.html",
        "open_in_tab": true
    }
}