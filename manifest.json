{
    "manifest_version": 3,
    "name": "Smart Search",
    "version": "1.0.0",
    "description": "A brief, plain text summary of the extension's purpose.",
    "action": {
        "default_title": "Click Me!",
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "./background/dist/background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "unlimitedStorage"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/loading-circle.gif"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "./content/dist/content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "commands": {
        "search-current-page": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Search in current page"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'"
    },
    "short_name": "AwesomeExt",
    "version_name": "1.0 Beta",
    "minimum_chrome_version": "102"
}